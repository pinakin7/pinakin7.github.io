---
import siteContent from '../data/site_content.json';

const { hero } = siteContent;

// Split a proof point like "45% reduction in manual monitoring"
// into a leading metric ("45%") and a label ("reduction in manual monitoring").
function splitMetric(point: string): { value: string; label: string } {
  const match = point.match(/^([0-9][0-9.,]*\s*(?:%|x|FPS|fps)?)\s+(.*)$/);
  if (match) {
    return { value: match[1].trim(), label: match[2].trim() };
  }
  return { value: '', label: point };
}

const metrics = hero.proof_points.map(splitMetric);
---

<section class="band">
  <div class="container-page py-12 sm:py-14">
    <h2 class="eyebrow reveal">Proof of impact</h2>
    <dl class="mt-8 grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-3">
      {
        metrics.map((m, i) => (
          <div class="reveal metric-cell" style={`--reveal-delay: ${i * 0.05}s;`}>
            <dt class="sr-only">{m.label}</dt>
            <dd>
              <span
                class="metric-num block text-3xl font-semibold sm:text-4xl"
                style="color: var(--color-ink);"
                data-count={m.value}
              >
                {m.value}
              </span>
              <span class="mt-2 block text-sm leading-snug" style="color: var(--color-muted);">
                {m.label}
              </span>
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .metric-cell {
    position: relative;
    padding-left: 1rem;
  }
  .metric-cell::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.3rem;
    bottom: 0.3rem;
    width: 2px;
    border-radius: 1px;
    background: linear-gradient(
      to bottom,
      var(--color-accent),
      rgba(139, 147, 255, 0.1)
    );
  }
</style>
