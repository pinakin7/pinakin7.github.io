---
import siteContent from '../data/site_content.json';
import Icon from './Icon.astro';

const { hero } = siteContent;

// Highlight the load-bearing phrase if present; fall back to plain text.
const HIGHLIGHT = 'production-grade AI systems';
const idx = hero.headline.indexOf(HIGHLIGHT);
const parts =
  idx === -1
    ? null
    : {
        before: hero.headline.slice(0, idx),
        after: hero.headline.slice(idx + HIGHLIGHT.length),
      };
---

<section class="relative">
  <div class="container-page pb-16 pt-20 sm:pb-24 sm:pt-28">
    <div class="max-w-3xl">
      <p class="eyebrow reveal">{hero.eyebrow}</p>

      <h1
        class="reveal mt-6 text-4xl font-semibold leading-[1.08] tracking-[-0.035em] text-balance sm:text-[3.4rem]"
        style="color: var(--color-ink); --reveal-delay: 0.06s;"
      >
        {
          parts ? (
            <>
              {parts.before}
              <span class="hero-highlight">{HIGHLIGHT}</span>
              {parts.after}
            </>
          ) : (
            hero.headline
          )
        }
      </h1>

      <p
        class="reveal mt-6 max-w-2xl text-lg leading-relaxed"
        style="color: var(--color-ink-soft); --reveal-delay: 0.12s;"
      >
        {hero.subheadline}
      </p>

      <div class="reveal mt-9 flex flex-wrap items-center gap-3" style="--reveal-delay: 0.18s;">
        <a class="btn btn-primary" href="/case-studies/">
          {hero.cta_primary}
          <Icon name="arrow-right" size={16} />
        </a>
        <a class="btn btn-secondary" href="/contact/">
          {hero.cta_secondary}
        </a>
      </div>

      <p class="reveal mt-8" style="--reveal-delay: 0.24s;">
        <span class="status-pill !rounded-xl text-left leading-relaxed">
          {hero.recruiter_pitch}
        </span>
      </p>
    </div>
  </div>
</section>

<style>
  .hero-highlight {
    background-image: linear-gradient(
      100deg,
      var(--color-accent-strong),
      #9fd8ff
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
</style>
