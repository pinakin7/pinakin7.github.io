---
interface ExperienceItem {
  company: string;
  role: string;
  dates: string;
  theme: string;
  summary: string;
  highlights: string[];
  tags: string[];
}

interface Props {
  experiences: ExperienceItem[];
  /** Compact = summary + tags only (home page). Full = all highlights. */
  compact?: boolean;
}

const { experiences, compact = false } = Astro.props;
---

<ol class="relative space-y-10 border-l-2 pl-6 sm:pl-8" style="border-color: var(--color-line);">
  {
    experiences.map((job) => (
      <li class="relative">
        <span
          class="absolute -left-[31px] top-1.5 h-3.5 w-3.5 rounded-full ring-4 ring-white sm:-left-[39px]"
          style="background-color: var(--color-accent);"
          aria-hidden="true"
        />

        <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
          <h3 class="text-lg font-bold tracking-tight" style="color: var(--color-ink);">
            {job.role}
            <span style="color: var(--color-accent);"> · {job.company}</span>
          </h3>
          <p class="metric-num text-sm font-medium" style="color: var(--color-muted);">
            {job.dates}
          </p>
        </div>

        <p class="mt-1 text-sm font-medium" style="color: var(--color-ink-soft);">
          {job.theme}
        </p>

        {compact ? (
          <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-ink-soft);">
            {job.summary}
          </p>
        ) : (
          <ul class="mt-4 space-y-2">
            {job.highlights.map((h) => (
              <li class="flex items-start gap-2 text-sm leading-relaxed" style="color: var(--color-ink-soft);">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full" style="background-color: var(--color-accent);" />
                <span>{h}</span>
              </li>
            ))}
          </ul>
        )}

        <div class="mt-4 flex flex-wrap gap-1.5">
          {job.tags.map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>
      </li>
    ))
  }
</ol>
