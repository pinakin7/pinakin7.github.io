---
interface ExperienceItem {
  company: string;
  role: string;
  dates: string;
  theme: string;
  summary: string;
  highlights: string[];
  tags: string[];
}

interface Props {
  experiences: ExperienceItem[];
  /** Compact = summary + tags only (home page). Full = all highlights. */
  compact?: boolean;
}

const { experiences, compact = false } = Astro.props;
---

<ol class="timeline relative space-y-12 pl-7 sm:pl-9">
  {
    experiences.map((job, i) => (
      <li class="reveal relative" style={`--reveal-delay: ${i * 0.06}s;`}>
        <span class="timeline-marker" aria-hidden="true" />

        <div class="flex flex-col gap-1.5 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
          <h3 class="text-lg font-semibold tracking-tight" style="color: var(--color-ink);">
            {job.role}
            <span class="font-medium" style="color: var(--color-accent);">
              {' '}· {job.company}
            </span>
          </h3>
          <p class="mono-label shrink-0">{job.dates}</p>
        </div>

        <p class="mt-1.5 text-sm font-medium" style="color: var(--color-ink-soft);">
          {job.theme}
        </p>

        {compact ? (
          <p class="mt-3 max-w-3xl text-sm leading-relaxed" style="color: var(--color-muted);">
            {job.summary}
          </p>
        ) : (
          <ul class="mt-4 max-w-3xl space-y-2.5">
            {job.highlights.map((h) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: var(--color-ink-soft);">
                <span
                  class="mt-[9px] h-px w-3.5 shrink-0"
                  style="background-color: var(--color-line-strong);"
                />
                <span>{h}</span>
              </li>
            ))}
          </ul>
        )}

        <div class="mt-4 flex flex-wrap gap-1.5">
          {job.tags.map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>
      </li>
    ))
  }
</ol>

<style>
  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: linear-gradient(
      to bottom,
      var(--color-accent) 0,
      var(--color-line) 120px,
      var(--color-line)
    );
  }
  .timeline-marker {
    position: absolute;
    left: calc(-1.75rem - 4.5px);
    top: 7px;
    height: 10px;
    width: 10px;
    border-radius: 9999px;
    border: 2px solid var(--color-accent);
    background-color: var(--color-canvas);
  }
  @media (min-width: 640px) {
    .timeline-marker {
      left: calc(-2.25rem - 4.5px);
    }
  }
</style>
