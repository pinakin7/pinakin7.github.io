---
import Icon from './Icon.astro';

interface Props {
  study: {
    id: string;
    title: string;
    category: string;
    one_liner: string;
    impact: string[];
    skills: string[];
  };
}

const { study } = Astro.props;
---

<a
  href={`/case-studies/${study.id}/`}
  class="card group flex h-full flex-col"
  aria-label={`Read case study: ${study.title}`}
>
  <p class="eyebrow">{study.category}</p>

  <h3
    class="mt-3 text-lg font-bold leading-snug tracking-tight"
    style="color: var(--color-ink);"
  >
    {study.title}
  </h3>

  <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-ink-soft);">
    {study.one_liner}
  </p>

  <ul class="mt-4 space-y-1.5">
    {
      study.impact.slice(0, 3).map((item) => (
        <li class="flex items-start gap-2 text-sm" style="color: var(--color-ink-soft);">
          <span style="color: var(--color-accent);" class="mt-0.5 shrink-0">
            <Icon name="check" size={15} />
          </span>
          <span>{item}</span>
        </li>
      ))
    }
  </ul>

  <div class="mt-5 flex flex-wrap gap-1.5">
    {study.skills.slice(0, 5).map((s) => <span class="tag">{s}</span>)}
  </div>

  <span
    class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold transition-transform group-hover:translate-x-0.5"
    style="color: var(--color-accent);"
  >
    Read case study
    <Icon name="arrow-right" size={16} />
  </span>
</a>
