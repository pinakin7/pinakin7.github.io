---
import siteContent from '../data/site_content.json';
import Icon from './Icon.astro';

interface Props {
  /** Full = standalone contact page; compact = home CTA band. */
  variant?: 'compact' | 'full';
}

const { variant = 'compact' } = Astro.props;
const { contact, hero } = siteContent;
const hasLinkedIn = contact.linkedin?.startsWith('http');

const channels = [
  { label: 'Email', value: contact.email, href: `mailto:${contact.email}`, icon: 'email' as const, external: false },
  { label: 'GitHub', value: 'github.com/pinakin7', href: contact.github, icon: 'github' as const, external: true },
  ...(hasLinkedIn
    ? [{ label: 'LinkedIn', value: 'LinkedIn profile', href: contact.linkedin, icon: 'linkedin' as const, external: true }]
    : []),
];
---

<div
  class:list={[
    'cta-panel reveal relative overflow-hidden',
    variant === 'compact' ? 'rounded-2xl border p-8 sm:p-12' : 'rounded-2xl border p-8 sm:p-12',
  ]}
  style="border-color: var(--color-line); background-color: var(--color-surface);"
>
  <!-- Accent bloom in the panel's top corner -->
  <div
    class="pointer-events-none absolute -right-24 -top-32 h-72 w-72 rounded-full"
    style="background: radial-gradient(closest-side, rgba(139,147,255,0.16), transparent); filter: blur(24px);"
    aria-hidden="true"
  >
  </div>

  <p class="eyebrow">Contact</p>
  <h2 class="mt-4 max-w-2xl text-2xl font-semibold tracking-tight text-balance sm:text-3xl" style="color: var(--color-ink); letter-spacing: -0.02em;">
    {contact.cta}
  </h2>
  <p class="mt-3 max-w-2xl text-sm leading-relaxed" style="color: var(--color-muted);">
    {hero.recruiter_pitch}
  </p>

  <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      channels.map((c) => (
        <a
          href={c.href}
          target={c.external ? '_blank' : undefined}
          rel={c.external ? 'noopener' : undefined}
          class="card card-hover group flex items-center gap-3.5 !p-4"
          style="background-color: var(--color-surface-2);"
        >
          <span
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border transition-colors"
            style="border-color: var(--color-line); background-color: var(--color-accent-soft); color: var(--color-accent);"
          >
            <Icon name={c.icon} size={18} />
          </span>
          <span class="min-w-0 flex-1">
            <span class="block text-sm font-semibold" style="color: var(--color-ink);">
              {c.label}
            </span>
            <span class="mono-label block truncate !text-[0.6875rem]">{c.value}</span>
          </span>
          <span
            class="shrink-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100"
            style="color: var(--color-muted);"
          >
            <Icon name={c.external ? 'arrow-up-right' : 'arrow-right'} size={15} />
          </span>
        </a>
      ))
    }
  </div>

  {
    !hasLinkedIn && (
      <p class="mono-label mt-4">LinkedIn link coming soon.</p>
    )
  }
</div>
