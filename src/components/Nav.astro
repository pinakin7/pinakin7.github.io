---
const links = [
  { label: 'Home', href: '/' },
  { label: 'Experience', href: '/experience/' },
  { label: 'Case Studies', href: '/case-studies/' },
  { label: 'Research', href: '/research/' },
  { label: 'Contact', href: '/contact/' },
];

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header
  class="sticky top-0 z-40 border-b backdrop-blur-md"
  style="border-color: var(--color-line); background-color: rgba(10, 10, 14, 0.78);"
>
  <nav class="container-page flex h-16 items-center justify-between" aria-label="Primary">
    <a href="/" class="group flex items-baseline gap-2.5" aria-label="Preet Viradiya — home">
      <span
        class="metric-num text-sm font-semibold"
        style="color: var(--color-accent);"
        aria-hidden="true">pv</span
      >
      <span class="text-[0.9375rem] font-semibold tracking-tight" style="color: var(--color-ink);">
        Preet Viradiya
      </span>
      <span class="mono-label hidden lg:inline">/ AI Systems Engineer</span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-0.5 md:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              aria-current={isActive(l.href) ? 'page' : undefined}
              class:list={[
                'relative rounded-md px-3 py-2 text-sm font-medium transition-colors duration-200',
                isActive(l.href) ? 'nav-active' : 'nav-idle',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }
      <li class="ml-3">
        <a
          href="/contact/"
          class="btn btn-primary !px-4 !py-2 !text-[0.8125rem]"
        >
          Get in touch
        </a>
      </li>
    </ul>

    <!-- Mobile toggle (CSS-only via <details>) -->
    <details class="relative md:hidden">
      <summary
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg border transition-colors"
        style="border-color: var(--color-line); color: var(--color-ink);"
        aria-label="Toggle menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="7" x2="21" y2="7"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="17" x2="21" y2="17"></line>
        </svg>
      </summary>
      <ul
        class="absolute right-0 mt-3 w-56 rounded-xl border p-1.5 shadow-2xl"
        style="border-color: var(--color-line-strong); background-color: var(--color-surface-2);"
      >
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                aria-current={isActive(l.href) ? 'page' : undefined}
                class="block rounded-lg px-3 py-2.5 text-sm font-medium transition-colors"
                style={
                  isActive(l.href)
                    ? 'color: var(--color-accent-strong); background-color: var(--color-accent-soft);'
                    : 'color: var(--color-ink-soft);'
                }
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </details>
  </nav>
</header>

<style>
  .nav-idle {
    color: var(--color-muted);
  }
  .nav-idle:hover {
    color: var(--color-ink);
  }
  .nav-active {
    color: var(--color-ink);
  }
  /* Active indicator: hairline underneath, aligned to the header border */
  .nav-active::after {
    content: '';
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    bottom: -0.8125rem;
    height: 2px;
    border-radius: 1px;
    background-color: var(--color-accent);
  }
</style>
