---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import CaseStudyBackdrop from '../../components/CaseStudyBackdrop.astro';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies');
  return studies.map((entry) => ({
    params: { id: entry.data.id },
    props: { study: entry.data },
  }));
}

const { study } = Astro.props;

// Split the leading metric out of each impact string for the metric cards.
function splitMetric(point: string): { value: string; label: string } {
  const match = point.match(/^([0-9][0-9.,]*\s*(?:%|x|FPS|fps)?)\s+(.*)$/);
  if (match) return { value: match[1].trim(), label: match[2].trim() };
  return { value: '', label: point };
}
const metrics = study.impact.map(splitMetric);
// First numeric impact value ("45%", "30 FPS") feeds the animated backdrop.
// Bare single digits are skipped — "3" alone reads as noise, "45%" reads as impact.
const ghostMetric = metrics.find((m) => m.value.length >= 2)?.value;
---

<BaseLayout
  title={`${study.title} | Preet Viradiya`}
  description={study.one_liner}
  path={`/case-studies/${study.id}/`}
  ogType="article"
>
  <article class="relative container-page py-12 sm:py-16">
    <!-- Project-themed motion backdrop behind the header area only -->
    <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[380px]">
      <CaseStudyBackdrop id={study.id} metric={ghostMetric} />
    </div>
    <a
      href="/case-studies/"
      class="group inline-flex items-center gap-1.5 text-sm font-medium transition-colors"
      style="color: var(--color-muted);"
    >
      <span class="transition-transform duration-200 group-hover:-translate-x-0.5">
        <Icon name="arrow-left" size={15} />
      </span>
      All case studies
    </a>

    <header class="mt-8 max-w-3xl">
      <p class="eyebrow reveal">{study.category}</p>
      <h1
        class="reveal mt-4 text-3xl font-semibold leading-tight tracking-tight text-balance sm:text-[2.5rem] sm:leading-[1.15]"
        style="color: var(--color-ink); letter-spacing: -0.03em; --reveal-delay: 0.06s;"
      >
        {study.title}
      </h1>
      <p
        class="reveal mt-5 text-lg leading-relaxed"
        style="color: var(--color-ink-soft); --reveal-delay: 0.12s;"
      >
        {study.one_liner}
      </p>
    </header>

    <!-- Impact metrics -->
    <section class="mt-12 grid grid-cols-2 gap-4 lg:grid-cols-4" aria-label="Impact">
      {
        metrics.map((m, i) => (
          <div class="card reveal !p-5" style={`--reveal-delay: ${i * 0.05}s;`}>
            {m.value && (
              <p
                class="metric-num text-2xl font-semibold sm:text-3xl"
                style="color: var(--color-ink);"
                data-count={m.value}
              >
                {m.value}
              </p>
            )}
            <p class="mt-1.5 text-sm leading-snug" style="color: var(--color-muted);">
              {m.label}
            </p>
          </div>
        ))
      }
    </section>

    <div class="mt-16 grid gap-12 lg:grid-cols-3">
      <!-- Main narrative -->
      <div class="space-y-12 lg:col-span-2">
        <section class="reveal">
          <h2 class="numbered-heading section-heading" data-num="01">The problem</h2>
          <p class="mt-4 leading-relaxed" style="color: var(--color-ink-soft);">{study.problem}</p>
        </section>

        <section class="reveal">
          <h2 class="numbered-heading section-heading" data-num="02">What I built</h2>
          <p class="mt-4 leading-relaxed" style="color: var(--color-ink-soft);">{study.solution}</p>
        </section>

        <section class="reveal">
          <h2 class="numbered-heading section-heading" data-num="03">Technical approach</h2>
          <ul class="mt-5 space-y-3">
            {
              study.technical_details.map((d) => (
                <li class="flex items-start gap-3 leading-relaxed" style="color: var(--color-ink-soft);">
                  <span class="mt-1 shrink-0" style="color: var(--color-signal);">
                    <Icon name="check" size={16} />
                  </span>
                  <span>{d}</span>
                </li>
              ))
            }
          </ul>
        </section>

        <!-- Visual placeholders (real diagrams to be added later) -->
        <section class="reveal">
          <h2 class="numbered-heading section-heading" data-num="04">Visuals</h2>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            {
              study.suggested_visuals.map((v) => (
                <div
                  class="mono-label flex min-h-32 items-center justify-center rounded-xl border border-dashed p-5 text-center leading-relaxed"
                  style="border-color: var(--color-line-strong); background-color: var(--color-surface);"
                >
                  {v}
                </div>
              ))
            }
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-5 lg:sticky lg:top-24 lg:self-start">
        <div class="card reveal">
          <h3 class="eyebrow !text-[0.625rem]" style="color: var(--color-muted);">
            Skills & tools
          </h3>
          <div class="mt-4 flex flex-wrap gap-1.5">
            {study.skills.map((s) => <span class="tag">{s}</span>)}
          </div>
        </div>

        <div
          class="card reveal"
          style="background-color: var(--color-accent-soft); border-color: rgba(139, 147, 255, 0.25); background-image: none;"
        >
          <h3 class="eyebrow !text-[0.625rem]">Why it matters</h3>
          <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-ink-soft);">
            {study.recruiter_angle}
          </p>
        </div>
      </aside>
    </div>

    <!-- Footer CTA -->
    <div class="mt-16 flex flex-wrap gap-3 border-t pt-10" style="border-color: var(--color-line);">
      <a class="btn btn-primary" href="/contact/">
        Get in touch
        <Icon name="arrow-right" size={16} />
      </a>
      <a class="btn btn-secondary" href="/case-studies/">More case studies</a>
    </div>
  </article>
</BaseLayout>

<style>
  .numbered-heading::before {
    content: attr(data-num);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.5rem;
  }
</style>
