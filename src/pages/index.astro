---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProofMetrics from '../components/ProofMetrics.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import SkillsGroups from '../components/SkillsGroups.astro';
import ResearchSection from '../components/ResearchSection.astro';
import ContactCTA from '../components/ContactCTA.astro';
import SectionHeader from '../components/SectionHeader.astro';
import siteContent from '../data/site_content.json';
import seo from '../data/seo.json';

const studies = await getCollection('caseStudies');
const featured = studies
  .map((s) => s.data)
  .filter((s) => s.homepage_featured)
  .sort((a, b) => a.priority - b.priority);
---

<BaseLayout
  title={seo.home.title}
  description={seo.home.description}
  keywords={seo.home.keywords}
  path="/"
  personSchema={true}
>
  <Hero />

  <ProofMetrics />

  <!-- Featured case studies -->
  <section class="container-page py-20 sm:py-24">
    <SectionHeader
      eyebrow="Featured work"
      title="Selected case studies"
      link={{ label: 'View all', href: '/case-studies/' }}
    />
    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {featured.map((study, i) => <CaseStudyCard study={study} index={i} />)}
    </div>
  </section>

  <!-- Experience snapshot -->
  <section class="band">
    <div class="container-page py-20 sm:py-24">
      <SectionHeader
        eyebrow="Experience"
        title="Where I've shipped AI systems"
        link={{ label: 'Full experience', href: '/experience/' }}
      />
      <div class="mt-12">
        <ExperienceTimeline experiences={siteContent.experience} compact={true} />
      </div>
    </div>
  </section>

  <!-- Skills by recruiter intent -->
  <section class="container-page py-20 sm:py-24">
    <SectionHeader eyebrow="Skills" title="Grouped by what you're hiring for" />
    <div class="mt-10">
      <SkillsGroups />
    </div>
  </section>

  <!-- Research -->
  <section class="band">
    <div class="container-page py-20 sm:py-24">
      <SectionHeader
        eyebrow="Research & writing"
        title="Where I go deep"
        link={{ label: 'More', href: '/research/' }}
      />
      <div class="mt-10">
        <ResearchSection />
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="container-page py-20 sm:py-24">
    <ContactCTA variant="compact" />
  </section>
</BaseLayout>
