---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import siteContent from '../data/site_content.json';
import seo from '../data/seo.json';

const { experience, education, about } = siteContent;
---

<BaseLayout
  title={seo.experience.title}
  description={seo.experience.description}
  keywords={seo.experience.keywords}
  path="/experience/"
>
  <section class="container-page py-16 sm:py-20">
    <p class="eyebrow">Experience</p>
    <h1 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl" style="color: var(--color-ink);">
      Professional experience
    </h1>
    <p class="mt-4 max-w-3xl text-base leading-relaxed" style="color: var(--color-ink-soft);">
      {about.short}
    </p>

    <div class="mt-12">
      <ExperienceTimeline experiences={experience} compact={false} />
    </div>

    <!-- Education -->
    <div class="mt-16">
      <h2 class="section-heading">Education</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2">
        {
          education.map((ed) => (
            <div class="card">
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                <h3 class="text-base font-bold tracking-tight" style="color: var(--color-ink);">
                  {ed.institution}
                </h3>
                <p class="metric-num text-sm" style="color: var(--color-muted);">
                  {ed.dates}
                </p>
              </div>
              <p class="mt-1 text-sm font-medium" style="color: var(--color-accent);">
                {ed.degree}
              </p>
              {'gpa' in ed && ed.gpa && (
                <p class="mt-1 text-sm" style="color: var(--color-ink-soft);">
                  GPA: <span class="metric-num">{ed.gpa}</span>
                </p>
              )}
              <p class="mt-4 text-xs font-semibold uppercase tracking-wide" style="color: var(--color-muted);">
                Selected coursework
              </p>
              <div class="mt-2 flex flex-wrap gap-1.5">
                {ed.coursework.map((c) => (
                  <span class="tag">{c}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
