---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResearchSection from '../components/ResearchSection.astro';
import PageHeader from '../components/PageHeader.astro';
import seo from '../data/seo.json';
---

<BaseLayout
  title={seo.research.title}
  description={seo.research.description}
  keywords={seo.research.keywords}
  path="/research/"
>
  <section class="container-page py-16 sm:py-24">
    <PageHeader
      eyebrow="Research & writing"
      title="Research interests"
      lede="Beyond shipping systems, I'm interested in how AI changes the way teams work and decide. My focus sits at the intersection of agentic systems, multimodal retrieval, edge reliability, and enterprise adoption — grounded in production constraints rather than benchmarks alone."
    />

    <div class="mt-12">
      <ResearchSection detailed={true} />
    </div>
  </section>
</BaseLayout>
